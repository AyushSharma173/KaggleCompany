# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Slack ===
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# === Kaggle ===
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# === GPU (Optional - needed for paid GPU training) ===
RUNPOD_API_KEY=your-runpod-api-key-here

# === Search (Parallel.ai — primary search/fetch provider) ===
PARALLEL_API_KEY=your-parallel-api-key-here

# === Startup ===
CLEAR_SLACK_ON_START=true   # Delete all channel messages on restart

# === Budget Defaults ===
GLOBAL_DAILY_BUDGET_USD=200.00
DEFAULT_AGENT_BUDGET_USD=200.00

# Heartbeat intervals — health monitor stuck detection is disabled.
VP_HEARTBEAT_INTERVAL_SECONDS=86400
WORKER_HEARTBEAT_INTERVAL_SECONDS=86400

# === Model Selection ===
DEFAULT_MODEL=claude-opus-4-6
REASONING_MODEL=claude-opus-4-6
HEARTBEAT_MODEL=claude-opus-4-6
RESEARCH_MODEL=claude-opus-4-6
